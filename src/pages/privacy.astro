---
import Breadcrumbs from '@components/Breadcrumbs.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { absoluteUrl, site } from '@data/site';

const title = 'Privacy Policy';
const description = 'Privacy policy template for AG Immo website inquiries and real estate lead handling.';
---
<BaseLayout title={title} description={description} canonical={absoluteUrl('/privacy')}>
  <Breadcrumbs items={[{ label: 'Privacy' }]} />
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy policy template</h1>
      <p>This page is a starter template and should be reviewed by a qualified professional before launch.</p>
    </div>
  </section>
  <section class="section-tight">
    <div class="container narrow article-body">
      <section>
        <h2>Information collected</h2>
        <p>When you contact {site.name}, you may provide your name, email, phone number, budget, preferred city and property requirements.</p>
      </section>
      <section>
        <h2>How it is used</h2>
        <p>Your information is used to respond to your inquiry, prepare property suggestions, coordinate visits and improve agency communication.</p>
      </section>
      <section>
        <h2>Contact</h2>
        <p>For privacy questions, contact <a href={`mailto:${site.email}`}>{site.email}</a>.</p>
      </section>
    </div>
  </section>
</BaseLayout>
