---
type FAQItem = {
  question: string;
  answer: string;
};

interface Props {
  items: readonly FAQItem[];
}

const { items } = Astro.props;
---
<section class="section faq-section" aria-labelledby="faq-title">
  <div class="container narrow">
    <p class="eyebrow">Questions buyers ask</p>
    <h2 id="faq-title">Morocco real estate FAQ</h2>
    <div class="faq-list">
      {items.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
