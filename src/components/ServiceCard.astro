---
interface Props {
  eyebrow: string;
  title: string;
  body: string;
  href: string;
  items?: string[];
}

const { eyebrow, title, body, href, items = [] } = Astro.props;
---
<article class="service-card">
  <p class="eyebrow">{eyebrow}</p>
  <h3>{title}</h3>
  <p>{body}</p>
  {items.length > 0 && (
    <ul class="check-list compact">
      {items.map((item) => <li>{item}</li>)}
    </ul>
  )}
  <a class="text-link" href={href}>Learn more</a>
</article>
