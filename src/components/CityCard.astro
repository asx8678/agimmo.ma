---
import type { Location } from '@data/locations';

interface Props {
  location: Location;
}

const { location } = Astro.props;
---
<article class="city-card">
  <p class="eyebrow">Morocco property market</p>
  <h3>{location.city}</h3>
  <p>{location.intro}</p>
  <ul class="tag-list" aria-label={`${location.city} neighborhoods`}>
    {location.neighborhoods.slice(0, 4).map((neighborhood) => <li>{neighborhood}</li>)}
  </ul>
  <a class="text-link" href={`/areas/${location.slug}`}>Explore {location.city}</a>
</article>
